# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
*.js.map
*.d.ts.map
*.tsbuildinfo

# ─── Tests & coverage ─────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test/fixtures/
!test/fixtures/.gitkeep

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
pip-log.txt

# ─── Cython build artifacts (compiled modules are shipped via package.json "files") ─
cython/build/
cython/*.c
cython/*.html
cython/*.cp*-win_amd64.pyd
cython/*.cpython-*.so
!cython/*.pyx
!cython/setup.py
!cython/__init__.py

# ─── Portable Python (auto-downloaded at runtime, never committed) ────────────
.ultra-parquet-converter/

# ─── Environment & secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
.npmrc

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Packaged tarballs ────────────────────────────────────────────────────────
*.tgz

# ─── Generated output data (NOT the source examples/ folder) ──────────────────
*.parquet
*.tmp
*.temp
tmp/
temp/
/data/

# ─── Package managers ─────────────────────────────────────────────────────────
yarn.lock
pnpm-lock.yaml
.yarn/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Editors / IDEs ───────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
.history/

# ─── Tooling caches ───────────────────────────────────────────────────────────
.turbo/
.cache/
