{
  "name": "ultra-parquet-converter",
  "version": "1.3.0",
  "description": "Professional hybrid Parquet converter with Native Python, Portable Python, Pyodide (WebAssembly) and Cython backends. No installation required.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ultra-parquet-converter": "dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:ts",
    "build:ts": "tsc",
    "build:cython": "powershell -Command \"cd cython; ../.venv/Scripts/python.exe setup.py build_ext --inplace\"",
    "build:full": "npm run build:ts && npm run build:cython",
    "dev": "tsc --watch",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "coverage": "jest --config jest.config.cjs --coverage",
    "coverage:open": "jest --config jest.config.cjs --coverage && start coverage/lcov-report/index.html",
    "lint": "tsc --noEmit",
    "prepare": "npm run build",
    "clean": "rimraf dist",
    "clean:all": "rimraf dist coverage node_modules"
  },
  "keywords": [
    "parquet",
    "converter",
    "csv",
    "tsv",
    "psv",
    "dsv",
    "xlsx",
    "json",
    "ndjson",
    "jsonl",
    "xml",
    "yaml",
    "html",
    "feather",
    "arrow",
    "orc",
    "avro",
    "sqlite",
    "spss",
    "sas",
    "stata",
    "streaming",
    "bigdata",
    "data-engineering",
    "apache-arrow",
    "pandas",
    "data-science",
    "etl",
    "analytics",
    "big-data",
    "file-converter",
    "data-conversion",
    "auto-repair",
    "benchmarking",
    "pyodide",
    "webassembly",
    "cython",
    "portable-python"
  ],
  "author": "Hepein Oficial x Brashkie",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@types/node-fetch": "^2.6.13",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "extract-zip": "^2.0.1",
    "glob": "^10.3.10",
    "node-fetch": "^2.7.0",
    "ora": "^5.4.1",
    "pyodide": "^0.24.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Brashkie/ultra-parquet-converter.git"
  },
  "bugs": {
    "url": "https://github.com/Brashkie/ultra-parquet-converter/issues"
  },
  "homepage": "https://github.com/Brashkie/ultra-parquet-converter#readme",
  "files": [
    "dist/",
    "python/",
    "cython/__init__.py",
    "cython/*.pyd",
    "cython/*.so",
    "web/",
    "README.md",
    "README.es.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
